{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "module": "NodeNext",           // 重点：强制转为 CJS
    "moduleResolution": "NodeNext",     // 重点：允许自动寻找 index.ts
    "target": "ESNext",
    "esModuleInterop": true,
    "allowJs": true,
    "noEmit": false,
    "allowImportingTsExtensions": true,
    "types": [
      "mocha",
    ]
  },
  "include": [
    "test/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
