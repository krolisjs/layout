{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "rootDir": "src",
    "declaration": true,
    "outDir": "dist",
    "emitDeclarationOnly": true,
    "noEmit": false,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.tsbuildinfo",
    "removeComments": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "lib": [
      "dom",
      "webworker",
      "esnext"
    ]
  },
  "exclude": [
    "node_modules",
    "dist",
    "test"
  ],
  "include": [
    "src/**/*"
  ]
}
